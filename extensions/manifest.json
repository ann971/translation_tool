{
  "manifest_version": 3,
  "name": "Tooltran",
  "version": "1.1.0",
  "description": "選取文字→浮動按鈕→滑入自動以 DeepL 翻譯為目標語言。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "sidePanel"],
  "host_permissions": [
    "https://api-free.deepl.com/*",
    "https://api.deepl.com/*",
    "https://api.dictionaryapi.dev/*",
    "https://api.ocr.space/*"
  ],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": { "default_title": "Tooltran" },
  "side_panel": { "default_path": "options.html" },
  "options_page": "options.html",
  "commands": {
    "start-cropping": {
      "suggested_key": { "default": "Alt+A" },
      "description": "開始框選漫畫翻譯"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    { "resources": ["content.css", "deepl.svg"], "matches": ["<all_urls>"] }
  ]
}
